# Required: API key for the OpenRouter LLM provider
# OPENROUTER_API_KEY=

# SSH public key for key-only authentication (optional)
# HERMES_SSH_PUBKEY="ssh-ed25519 AAAAC3..."

# Set to 1 to enable the web dashboard (optional, default: 0)
# HERMES_DASHBOARD=1

# Dashboard bind address (optional, default: 0.0.0.0)
# HERMES_DASHBOARD_HOST=0.0.0.0

# Dashboard listen port (optional, default: 9119)
# HERMES_DASHBOARD_PORT=9119

# Telegram bot integration token (optional)
# TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram usernames allowed to interact (optional)
# TELEGRAM_ALLOWED_USERS=

# UID for /opt/data ownership (optional, default: 10000)
# HERMES_UID=10000

# GID for /opt/data ownership (optional, default: 10000)
# HERMES_GID=10000
