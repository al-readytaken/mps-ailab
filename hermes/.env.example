# ── Hermes Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values

# Required: OpenRouter API key
# OPENROUTER_API_KEY=

# API server key (auto-generated if unset)
# API_SERVER_KEY=

# Required for Telegram: bot token from @BotFather
# TELEGRAM_BOT_TOKEN=

# Required for Telegram: comma-separated list of allowed user IDs
# TELEGRAM_ALLOWED_USERS=

# Telegram home channel (chat ID where bot sends messages)
# TELEGRAM_HOME_CHANNEL=623794419

# Telegram home channel thread ID (optional, for forum topics)
# TELEGRAM_HOME_CHANNEL_THREAD_ID=

# Telegram model overrides (optional, defaults to gateway model)
# TELEGRAM_MODEL_PROVIDER=openrouter
# TELEGRAM_MODEL_NAME=deepseek/deepseek-v4-pro

# UID for /home/hermes/.hermes ownership (optional, default: 1000)
# HERMES_UID=1000

# GID for /home/hermes/.hermes ownership (optional, default: 1000)
# HERMES_GID=1000

# SSH public key for passwordless access
# HERMES_SSH_PUBKEY="ssh-rsa AAAA..."