# Model to pre-download on startup (optional)
# NOTE: Model name must be a valid search term for `lms get`.
# Run `lms get <name>` to test before setting.
# LMSTUDIO_MODEL=llama-3.2-1b-instruct

# Whether to pre-download the model at boot (optional, default: false)
# Set to true only after confirming the model name works with `lms get`.
# LMSTUDIO_PRELOAD=false
