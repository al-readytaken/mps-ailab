# SSH public key for key-only authentication (optional)
# Without this, sshd still starts but root login has no authorized keys.
# OPENCODE_SSH_PUBKEY="ssh-ed25519 AAAAC3..."

# UID for /root/.config/opencode ownership (optional, default: 1000)
# Set to your host user's UID so you can edit config files directly
# OPENCODE_UID=1000

# GID for /root/.config/opencode ownership (optional, default: 1000)
# OPENCODE_GID=1000

# OpenRouter API key — opencode detects this automatically
# Uncomment and set your key to use OpenRouter models
# OPENROUTER_API_KEY="sk-or-v1-..."
